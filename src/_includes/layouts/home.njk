---
layout: layouts/base.njk
---
<h1>{{ site.title }}</h1>
<p class="subtitle">{{ site.tagline }}</p>

{{ content | safe }}

{%- if collections.posts | length %}
<h2>Writing</h2>
<ul>
  {%- for post in collections.posts %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <span class="subtitle"><time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | readableDate }}</time></span>
    {%- if post.data.subtitle %}<br /><span class="subtitle">{{ post.data.subtitle }}</span>{% endif %}
  </li>
  {%- endfor %}
</ul>
{%- else %}
<h2>Projects</h2>
<p>No posts yet — the writing's coming. Until then, the code is the proof:
<a href="/projects/">see what I've built →</a></p>
{%- endif %}
